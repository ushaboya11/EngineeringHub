import sys

def solve():
    data = sys.stdin.read().strip().split()
    t = int(data[0])
    idx = 1
    out = []
    for _ in range(t):
        X = int(data[idx]); Y = int(data[idx+1]); Z = int(data[idx+2])
        idx += 3
        breaks = (X - 1) // 3
        total = X * Y + breaks * Z
        out.append(str(total))
    print("\n".join(out))

if __name__ == "__main__":
    solve()

