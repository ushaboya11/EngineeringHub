# Flip the cards - CodeChef Problem FLIPCARDS

# Read number of test cases
T = int(input().strip())

for _ in range(T):
    # Read N (total cards) and X (face-up cards)
    N, X = map(int, input().split())
    
    # Cards facing down = N - X
    face_down = N - X
    
    # Minimum flips = min(X, face_down)
    result = min(X, face_down)
    
    print(result)
