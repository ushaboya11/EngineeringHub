import sys

def min_coins(x):
    if x % 5 != 0:
        return -1
    return x // 10 + (1 if x % 10 else 0)

def main():
    data = sys.stdin.read().strip().split()
    t = int(data[0])
    out = []
    for i in range(1, t + 1):
        x = int(data[i])
        out.append(str(min_coins(x)))
    print("\n".join(out))

if __name__ == "__main__":
    main()
