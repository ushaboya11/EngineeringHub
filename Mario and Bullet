import sys

def solve():
    data = sys.stdin.read().strip().split()
    t = int(data[0])
    idx = 1
    out = []
    for _ in range(t):
        X = int(data[idx]); Y = int(data[idx+1]); Z = int(data[idx+2])
        idx += 3
        hit_time = Y // X  # integer due to X divides Y
        delay = max(0, Z - hit_time)
        out.append(str(delay))
    print("\n".join(out))

if __name__ == "__main__":
    solve()

