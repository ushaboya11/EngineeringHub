# Cyclic Quadrilateral - CodeChef Problem CYCLICQD

# Read number of test cases
T = int(input().strip())

for _ in range(T):
    # Read four angles
    A, B, C, D = map(int, input().split())
    
    # A quadrilateral is cyclic if sum of opposite angles = 180
    if (A + C == 180) or (B + D == 180):
        print("YES")
    else:
        print("NO")
