# Qualify the round - CodeChef Problem QUALIFY

# Read number of test cases
T = int(input().strip())

for _ in range(T):
    # Read X, A, B
    X, A, B = map(int, input().split())
    
    # Calculate total score
    score = A * 1 + B * 2
    
    # Check qualification
    if score >= X:
        print("Qualify")
    else:
        print("NotQualify")
