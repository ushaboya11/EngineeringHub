# Sasta Shark Tank - CodeChef Problem SST

# Read number of test cases
T = int(input().strip())

for _ in range(T):
    # Read A and B
    A, B = map(int, input().split())
    
    # Calculate valuations
    valuation_first = A * 10   # since A is for 10%
    valuation_second = B * 5   # since B is for 20%
    
    # Compare valuations
    if valuation_first > valuation_second:
        print("FIRST")
    elif valuation_second > valuation_first:
        print("SECOND")
    else:
        print("ANY")
